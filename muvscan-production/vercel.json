  "framework": "nextjs",
  "regions": ["iad1"],
  "installCommand": "yarn install --non-interactive --ignore-engines",
  "buildCommand": "yarn build",
  "functions": {
    "app/api/scan/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
